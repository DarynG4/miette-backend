{
  "name": "miette-backend",
  "version": "1.0.0",
  "description": "Backend API for Miette — a sewing project tracker with a social layer",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
